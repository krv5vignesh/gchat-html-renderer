{
  "manifest_version": 3,
  "name": "Google Chat HTML Renderer",
  "version": "1.4.4",
  "description": "Automatically renders raw HTML attachments inside the Google Chat file viewer.",
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "gchat-html-renderer@mushtaq",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["sandbox.html", "viewer.html"],
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
