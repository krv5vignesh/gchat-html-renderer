{
  "manifest_version": 3,
  "name": "Google Chat HTML Renderer",
  "version": "1.4",
  "description": "Automatically renders raw HTML attachments inside the Google Chat file viewer.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/chat/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["sandbox.html", "viewer.html"],
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
